{
  "name": "filesystem",
  "version": "0.1.0",
  "description": "Scoped local file access through the MCP reference filesystem server.",
  "author": {
    "name": "OpenCoven"
  },
  "homepage": "https://opencoven.ai",
  "repository": "https://github.com/OpenCoven/coven-cave",
  "license": "GPL-3.0",
  "keywords": [
    "filesystem",
    "files",
    "local",
    "reference-mcp"
  ],
  "capabilities": [
    "read_files",
    "write_files",
    "mcp"
  ],
  "marketplaceId": "opencoven/filesystem",
  "x-coven": {
    "displayName": "Filesystem",
    "category": "Core MCP",
    "trust": "reference-local",
    "sourceRefs": [
      "https://github.com/modelcontextprotocol/servers"
    ],
    "roleAffinity": [
      {
        "familiar": "cody",
        "roles": [
          "implementer",
          "debugger"
        ]
      },
      {
        "familiar": "sage",
        "roles": [
          "researcher",
          "librarian"
        ]
      },
      {
        "familiar": "echo",
        "roles": [
          "archivist"
        ]
      },
      {
        "familiar": "kitty",
        "roles": [
          "general-helper"
        ]
      }
    ],
    "compatibility": {
      "covenCave": true,
      "covenCode": true,
      "codex": true,
      "mcp": true,
      "rolePatch": true
    }
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${COVEN_MCP_FILESYSTEM_ROOT}"
      ],
      "type": "stdio"
    }
  },
  "userConfig": {
    "filesystem_root": {
      "type": "directory",
      "title": "Allowed Filesystem Root",
      "description": "Root directory the filesystem MCP server may access.",
      "required": true,
      "sensitive": false,
      "env": "COVEN_MCP_FILESYSTEM_ROOT"
    }
  }
}
