{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "loopback-browser",
  "description": "allows only the trusted main loopback webview to control native browser and terminal surfaces",
  "webviews": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "http://[\\:\\:1]:*/*"
    ]
  },
  "permissions": [
    "allow-pty-start",
    "allow-pty-write",
    "allow-pty-resize",
    "allow-pty-stop",
    "allow-pty-list",
    "allow-pty-diagnose",
    "allow-browser-navigate",
    "allow-browser-set-bounds",
    "allow-browser-hide",
    "allow-browser-hide-all-except",
    "allow-browser-close",
    "allow-browser-deactivate-all",
    "allow-browser-close-all",
    "allow-browser-reload"
  ]
}
